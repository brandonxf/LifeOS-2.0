# ─── Database (Neon serverless PostgreSQL) ─────────────────────────────
# Create a project at https://neon.tech and copy the pooled connection string.
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ─── Redis (Upstash recommended for serverless) ────────────────────────
# Create a database at https://upstash.com and copy the redis:// URL.
REDIS_URL="rediss://default:password@xxxx.upstash.io:6379"

# ─── JWT secrets (generate with: openssl rand -base64 48) ──────────────
JWT_SECRET="change-me-access-token-secret"
JWT_REFRESH_SECRET="change-me-refresh-token-secret"

# ─── AI provider ───────────────────────────────────────────────────────
# Option 1 (recommended, free): NVIDIA NIM — OpenAI-compatible, many free models.
# Get a key at https://build.nvidia.com (starts with "nvapi-").
NVIDIA_API_KEY="nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"
AI_MODEL="meta/llama-3.1-8b-instruct"

# Option 2: Anthropic Claude (used only if NVIDIA_API_KEY is empty).
ANTHROPIC_API_KEY=""

# ─── Server ─────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CLIENT_URL="http://localhost:5173"

# ─── Client (Vite) ──────────────────────────────────────────────────────
VITE_API_URL="http://localhost:4000"
